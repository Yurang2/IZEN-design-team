# Frontend API base URL. Default is /api.
# Example (local worker): http://127.0.0.1:8787/api
# Example (prod worker): https://<worker-name>.<subdomain>.workers.dev/api
VITE_API_BASE_URL=/api

# Firebase Studio/Web Preview 등 백엔드 없이 화면을 점검할 때 true로 설정
# 또는 URL에 ?demo=1 을 붙여도 mock 모드가 켜집니다.
VITE_USE_MOCK_DATA=false
