{
  "name": "myapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node -e \"require('fs').copyFileSync('index.template.html','index.html')\"",
    "dev": "vite",
    "dev:worker": "bash ./scripts/run-worker.sh dev",
    "deploy:worker": "bash ./scripts/run-worker.sh deploy",
    "prebuild": "node -e \"require('fs').copyFileSync('index.template.html','index.html')\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "pages:prune": "node scripts/prune-pages-deployments.mjs --keep=3",
    "preview": "vite preview",
    "publish:web": "bash ./scripts/publish-web.sh",
    "generate:event-graphics-draft": "node scripts/generate-event-graphics-timetable-draft.mjs && node scripts/augment-event-graphics-entrance-cues.mjs",
    "sync:event-graphics-masterfiles": "node scripts/sync-event-graphics-masterfile-assets.mjs",
    "sync:screening-video-schema": "node scripts/sync-screening-video-schema-direct.mjs",
    "watch:event-graphics-masterfiles": "node scripts/watch-event-graphics-masterfile-assets.mjs",
    "import:event-graphics-draft": "node scripts/import-event-graphics-timetable-draft.mjs",
    "import:event-graphics-direct": "node scripts/import-event-graphics-timetable-direct.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
